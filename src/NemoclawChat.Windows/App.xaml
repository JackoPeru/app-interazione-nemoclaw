<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NemoclawChat_Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NemoclawChat_Windows"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Shared visual language with Android AppColors. -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF0B0D10" />
            <SolidColorBrush x:Key="SidebarBrush" Color="#FF101318" />
            <SolidColorBrush x:Key="SidebarHoverBrush" Color="#FF20242C" />
            <SolidColorBrush x:Key="ComposerBrush" Color="#FF171A20" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FF181C23" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF12151A" />
            <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="#FF20242C" />
            <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#FF1F242E" />
            <SolidColorBrush x:Key="UserBubbleBrush" Color="#FF3E2918" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#FFC8D2E0" />
            <SolidColorBrush x:Key="FaintTextBrush" Color="#FF8F99A8" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FFF5A524" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="#FFF5A524" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFFFC857" />
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="#FF302517" />
            <SolidColorBrush x:Key="AccentBorderBrush" Color="#47F5A524" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF65D38E" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFFFB24A" />
            <SolidColorBrush x:Key="BorderBrushSoft" Color="#FF292E37" />
            <SolidColorBrush x:Key="BorderBrushStrong" Color="#FF343B47" />

            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style
                x:Key="SidebarSelectedButtonStyle"
                BasedOn="{StaticResource SidebarButtonStyle}"
                TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderBrush" Value="#44F5A524" />
            </Style>

            <Style x:Key="SidebarSectionLabelStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="12,14,12,4" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="110" />
                <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
            </Style>

            <Style x:Key="ShellIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="QuickActionButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="48" />
                <Setter Property="Padding" Value="15,12" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="White" />
            </Style>

            <Style x:Key="PremiumCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="Padding" Value="16" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
