<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NemoclawChat_Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NemoclawChat_Windows">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF212121" />
            <SolidColorBrush x:Key="SidebarBrush" Color="#FF171717" />
            <SolidColorBrush x:Key="SidebarHoverBrush" Color="#FF2F2F2F" />
            <SolidColorBrush x:Key="ComposerBrush" Color="#FF303030" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FF2B2B2B" />
            <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#FF282828" />
            <SolidColorBrush x:Key="UserBubbleBrush" Color="#FF3A3A3A" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#FFB4B4B4" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="#FF10A37F" />

            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="MinHeight" Value="38" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
