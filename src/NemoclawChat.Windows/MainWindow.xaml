<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NemoclawChat_Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NemoclawChat_Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Nemoclaw Chat"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Padding="14,16,14,14"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#FF303030"
            BorderThickness="0,0,1,0">
            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Nemoclaw" />
                    <Button
                        Grid.Column="1"
                        Width="34"
                        Height="34"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CollapseSidebar_Click"
                        Foreground="{StaticResource MutedTextBrush}">
                        <FontIcon FontSize="14" Glyph="&#xE700;" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="4">
                    <Button Click="NewChat_Click" Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE710;" />
                            <TextBlock Text="Nuova chat" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE721;" />
                            <TextBlock Text="Cerca chat" />
                        </StackPanel>
                    </Button>
                    <Button Click="Tasks_Click" Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE7C1;" />
                            <TextBlock Text="Ordini agente" />
                        </StackPanel>
                    </Button>
                    <Button Click="Server_Click" Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE968;" />
                            <TextBlock Text="Server" />
                        </StackPanel>
                    </Button>
                    <Button Click="Settings_Click" Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE713;" />
                            <TextBlock Text="Impostazioni" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="18">
                    <TextBlock
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Progetti" />
                    <TextBlock
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Recenti" />
                    <StackPanel Spacing="4">
                        <Button Click="OpenChat_Click" Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock Text="Setup gateway NemoClaw" />
                        </Button>
                        <Button Click="OpenChat_Click" Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock Text="Test modello locale" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="3" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="28"
                        Height="28"
                        Background="#FF9B59B6"
                        CornerRadius="14">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="MP" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Matteo" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Server locale" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="DragRegion"
                Background="{StaticResource AppBackgroundBrush}">
                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Padding="0,0,16,0"
                    Spacing="10">
                    <Border
                        Padding="10,5"
                        Background="#FF2A2A2A"
                        CornerRadius="12">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Gateway preset: nemoclaw.local" />
                    </Border>
                    <Button
                        Width="32"
                        Height="32"
                        Click="Settings_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource MutedTextBrush}">
                        <FontIcon FontSize="14" Glyph="&#xE713;" />
                    </Button>
                </StackPanel>
            </Grid>

            <Frame x:Name="ContentFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
