<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NemoclawChat_Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NemoclawChat_Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Hermes Hub"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="K" Modifiers="Control" Invoked="SearchAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="Sidebar"
            Grid.Column="0"
            Padding="14,16,14,14"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="0,0,1,0">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="44"
                        Height="44"
                        Background="{StaticResource PanelBrush}"
                        CornerRadius="14">
                        <Image
                            Source="ms-appx:///Assets/ChatClawLogo.png"
                            Stretch="UniformToFill" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="1">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Hermes Hub" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource FaintTextBrush}"
                            Text="Hermes Agent · desktop" />
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        Click="CollapseSidebar_Click"
                        Style="{StaticResource ShellIconButtonStyle}"
                        AutomationProperties.Name="Comprimi sidebar"
                        ToolTipService.ToolTip="Comprimi sidebar">
                        <FontIcon FontSize="15" Glyph="&#xE700;" />
                    </Button>
                </Grid>

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">
                        <Button
                            x:Name="NavNewChatButton"
                            Click="NewChat_Click"
                            Style="{StaticResource SidebarSelectedButtonStyle}"
                            AutomationProperties.Name="Nuova chat"
                            ToolTipService.ToolTip="Nuova chat">
                            <StackPanel Orientation="Horizontal" Spacing="11">
                                <FontIcon FontSize="17" Glyph="&#xE710;" />
                                <TextBlock FontWeight="SemiBold" Text="Nuova chat" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="NavArchiveButton"
                            Click="Archive_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            AutomationProperties.Name="Archivio chat"
                            ToolTipService.ToolTip="Archivio chat">
                            <StackPanel Orientation="Horizontal" Spacing="11">
                                <FontIcon FontSize="17" Glyph="&#xE8B7;" />
                                <TextBlock Text="Archivio chat" />
                            </StackPanel>
                        </Button>

                        <TextBlock Style="{StaticResource SidebarSectionLabelStyle}" Text="OPERATIVITÀ" />
                        <Button x:Name="NavProjectsButton" Click="Projects_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Progetti" ToolTipService.ToolTip="Progetti">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE8F1;" /><TextBlock Text="Progetti" /></StackPanel>
                        </Button>
                        <Button x:Name="NavCronButton" Click="Cron_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Cron Hermes" ToolTipService.ToolTip="Cron Hermes">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE7C1;" /><TextBlock Text="Cron" /></StackPanel>
                        </Button>
                        <Button x:Name="NavNotificationsButton" Click="Notifications_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Notifiche Hermes" ToolTipService.ToolTip="Notifiche Hermes">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE91C;" /><TextBlock Text="Notifiche" /></StackPanel>
                        </Button>
                        <Button x:Name="NavContinuityButton" Click="Continuity_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Continuità dispositivi" ToolTipService.ToolTip="Continuità dispositivi">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE8C8;" /><TextBlock Text="Continuità" /></StackPanel>
                        </Button>
                        <Button x:Name="NavAuditButton" Click="Audit_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Timeline audit" ToolTipService.ToolTip="Timeline audit">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE9D5;" /><TextBlock Text="Audit" /></StackPanel>
                        </Button>
                        <Button x:Name="NavSearchButton" Click="Search_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Ricerca universale" ToolTipService.ToolTip="Ricerca universale (Ctrl+K)">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE721;" /><TextBlock Text="Ricerca globale" /></StackPanel>
                        </Button>
                        <Button x:Name="NavServerButton" Click="Server_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Server Hermes" ToolTipService.ToolTip="Server Hermes">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE968;" /><TextBlock Text="Server" /></StackPanel>
                        </Button>
                        <Button x:Name="NavHardwareButton" Click="Hardware_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Prestazioni hardware" ToolTipService.ToolTip="Prestazioni hardware">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE9D9;" /><TextBlock Text="Prestazioni" /></StackPanel>
                        </Button>

                        <TextBlock Style="{StaticResource SidebarSectionLabelStyle}" Text="CREAZIONE" />
                        <Button x:Name="NavVoiceButton" Click="Voice_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Voce" ToolTipService.ToolTip="Voce">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE720;" /><TextBlock Text="Voce" /></StackPanel>
                        </Button>
                        <Button x:Name="NavVideoButton" Click="Video_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Video" ToolTipService.ToolTip="Video">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE714;" /><TextBlock Text="Video" /></StackPanel>
                        </Button>
                        <Button x:Name="NavArtifactsButton" Click="Artifacts_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Artifact" ToolTipService.ToolTip="Artifact">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE8B7;" /><TextBlock Text="Artifact" /></StackPanel>
                        </Button>
                        <Button x:Name="NavNewsButton" Click="News_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="News" ToolTipService.ToolTip="News">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE789;" /><TextBlock Text="News" /></StackPanel>
                        </Button>

                        <TextBlock Style="{StaticResource SidebarSectionLabelStyle}" Text="RECENTI" />
                        <StackPanel x:Name="RecentChatsPanel" Spacing="4" />

                        <TextBlock Style="{StaticResource SidebarSectionLabelStyle}" Text="SISTEMA" />
                        <Button x:Name="NavSettingsButton" Click="Settings_Click" Style="{StaticResource SidebarButtonStyle}" AutomationProperties.Name="Impostazioni" ToolTipService.ToolTip="Impostazioni">
                            <StackPanel Orientation="Horizontal" Spacing="11"><FontIcon FontSize="16" Glyph="&#xE713;" /><TextBlock Text="Impostazioni" /></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Button
                    x:Name="ProfileButton"
                    Grid.Row="2"
                    Click="About_Click"
                    Style="{StaticResource SidebarButtonStyle}"
                    HorizontalContentAlignment="Stretch"
                    AutomationProperties.Name="Profilo"
                    ToolTipService.ToolTip="Profilo">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="32"
                            Height="32"
                            Background="{StaticResource AccentSubtleBrush}"
                            CornerRadius="16">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{StaticResource AccentBrush}"
                                Text="MP" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White" Text="Profilo locale" />
                            <TextBlock FontSize="10" Foreground="{StaticResource FaintTextBrush}" Text="Hermes locale" />
                        </StackPanel>
                        <FontIcon Grid.Column="2" FontSize="12" Glyph="&#xE76C;" Foreground="{StaticResource FaintTextBrush}" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="68" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                x:Name="DragRegion"
                Background="{StaticResource AppBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
                <Grid Padding="16,0,16,0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="RestoreSidebarButton"
                        Click="CollapseSidebar_Click"
                        Style="{StaticResource ShellIconButtonStyle}"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Mostra sidebar"
                        ToolTipService.ToolTip="Mostra sidebar">
                        <FontIcon FontSize="16" Glyph="&#xE8A0;" />
                    </Button>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="1">
                        <TextBlock
                            x:Name="ShellPageTitle"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Chat" />
                        <TextBlock
                            x:Name="ShellPageSubtitle"
                            FontSize="11"
                            Foreground="{StaticResource FaintTextBrush}"
                            Text="Hermes Hub" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="4">
                        <Button Click="NewChat_Click" Style="{StaticResource ShellIconButtonStyle}" AutomationProperties.Name="Nuova chat" ToolTipService.ToolTip="Nuova chat">
                            <FontIcon FontSize="16" Glyph="&#xE70F;" Foreground="{StaticResource AccentBrush}" />
                        </Button>
                        <Button Click="Settings_Click" Style="{StaticResource ShellIconButtonStyle}" AutomationProperties.Name="Impostazioni" ToolTipService.ToolTip="Impostazioni">
                            <FontIcon FontSize="16" Glyph="&#xE713;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
