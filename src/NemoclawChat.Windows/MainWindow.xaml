<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NemoclawChat_Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NemoclawChat_Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Hermes Hub"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="Sidebar"
            Grid.Column="0"
            Padding="14,16,14,14"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#FF303030"
            BorderThickness="0,0,1,0">
            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40"
                        Height="40"
                        Background="#FF0A0F16"
                        CornerRadius="12">
                        <Image
                            Width="40"
                            Height="40"
                            Source="ms-appx:///Assets/ChatClawLogo.png"
                            Stretch="UniformToFill" />
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Hermes Hub" />
                    <Button
                        Grid.Column="2"
                        Width="34"
                        Height="34"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CollapseSidebar_Click"
                        Foreground="{StaticResource MutedTextBrush}"
                        AutomationProperties.Name="Comprimi sidebar"
                        ToolTipService.ToolTip="Comprimi sidebar">
                        <FontIcon FontSize="14" Glyph="&#xE700;" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="4">
                    <Button Click="NewChat_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Nuova chat" AutomationProperties.Name="Nuova chat">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE710;" />
                            <TextBlock Text="Nuova chat" />
                        </StackPanel>
                    </Button>
                    <Button Click="Archive_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Archivio chat" AutomationProperties.Name="Archivio chat">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE721;" />
                            <TextBlock Text="Cerca chat" />
                        </StackPanel>
                    </Button>
                    <Button Click="Tasks_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Jobs Hermes" AutomationProperties.Name="Jobs Hermes">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE7C1;" />
                            <TextBlock Text="Jobs" />
                        </StackPanel>
                    </Button>
                    <Button Click="Server_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Server Hermes" AutomationProperties.Name="Server Hermes">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE968;" />
                            <TextBlock Text="Server" />
                        </StackPanel>
                    </Button>
                    <Button Click="Operator_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Runs Hermes" AutomationProperties.Name="Runs Hermes">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE950;" />
                            <TextBlock Text="Runs" />
                        </StackPanel>
                    </Button>
                    <Button Click="Video_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Video" AutomationProperties.Name="Video">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE714;" />
                            <TextBlock Text="Video" />
                        </StackPanel>
                    </Button>
                    <Button Click="News_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="News" AutomationProperties.Name="News">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE789;" />
                            <TextBlock Text="News" />
                        </StackPanel>
                    </Button>
                    <Button Click="Settings_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Impostazioni" AutomationProperties.Name="Impostazioni">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE713;" />
                            <TextBlock Text="Impostazioni" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="18">
                    <Button Click="Archive_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Progetti" AutomationProperties.Name="Progetti">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Progetti" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text=">" />
                        </StackPanel>
                    </Button>
                    <Button Click="Archive_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Recenti" AutomationProperties.Name="Recenti">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Recenti" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text=">" />
                        </StackPanel>
                    </Button>
                    <StackPanel x:Name="RecentChatsPanel" Spacing="4" />
                </StackPanel>

                <Grid Grid.Row="3" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="28"
                        Height="28"
                        Background="#FF9B59B6"
                        CornerRadius="14">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="MP" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Matteo" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Hermes locale" />
                    </StackPanel>
                    <Button
                        Grid.ColumnSpan="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="About_Click"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        ToolTipService.ToolTip="Profilo"
                        AutomationProperties.Name="Profilo" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="DragRegion"
                Background="{StaticResource AppBackgroundBrush}">
                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Padding="16,0,0,0">
                    <Button
                        x:Name="RestoreSidebarButton"
                        Width="32"
                        Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CollapseSidebar_Click"
                        Foreground="{StaticResource MutedTextBrush}"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Mostra sidebar"
                        AutomationProperties.Name="Mostra sidebar">
                        <FontIcon FontSize="14" Glyph="&#xE8A0;" />
                    </Button>
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Padding="0,0,16,0"
                    Spacing="10">
                    <Border
                        Padding="10,5"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Hermes preset: hermes.local" />
                    </Border>
                    <Button
                        Width="32"
                        Height="32"
                        Click="Settings_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource MutedTextBrush}"
                        ToolTipService.ToolTip="Impostazioni"
                        AutomationProperties.Name="Impostazioni">
                        <FontIcon FontSize="14" Glyph="&#xE713;" />
                    </Button>
                </StackPanel>
            </Grid>

            <Frame x:Name="ContentFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
