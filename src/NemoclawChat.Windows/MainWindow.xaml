<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NemoclawChat_Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NemoclawChat_Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Hermes Hub"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="K" Modifiers="Control" Invoked="SearchAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="Sidebar"
            Grid.Column="0"
            Padding="14,16,14,14"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#FF303030"
            BorderThickness="0,0,1,0">
            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40"
                        Height="40"
                        Background="#FF0A0F16"
                        CornerRadius="12">
                        <Image
                            Width="40"
                            Height="40"
                            Source="ms-appx:///Assets/ChatClawLogo.png"
                            Stretch="UniformToFill" />
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Hermes Hub" />
                    <Button
                        Grid.Column="2"
                        Width="34"
                        Height="34"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CollapseSidebar_Click"
                        Foreground="{StaticResource MutedTextBrush}"
                        AutomationProperties.Name="Comprimi sidebar"
                        ToolTipService.ToolTip="Comprimi sidebar">
                        <FontIcon FontSize="14" Glyph="&#xE700;" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="4">
                    <Button Click="NewChat_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Nuova chat" AutomationProperties.Name="Nuova chat">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE710;" />
                            <TextBlock Text="Nuova chat" />
                        </StackPanel>
                    </Button>
                    <Button Click="Archive_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Archivio chat" AutomationProperties.Name="Archivio chat">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE721;" />
                            <TextBlock Text="Cerca chat" />
                        </StackPanel>
                    </Button>
                    <Button Click="Cron_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Cron Hermes" AutomationProperties.Name="Cron Hermes">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE7C1;" />
                            <TextBlock Text="Cron" />
                        </StackPanel>
                    </Button>
                    <Button Click="Notifications_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Notifiche Hermes" AutomationProperties.Name="Notifiche Hermes">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE91C;" />
                            <TextBlock Text="Notifiche" />
                        </StackPanel>
                    </Button>
                    <Button Click="Server_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Server Hermes" AutomationProperties.Name="Server Hermes">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE968;" />
                            <TextBlock Text="Server" />
                        </StackPanel>
                    </Button>
                    <Button Click="Hardware_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Prestazioni hardware" AutomationProperties.Name="Prestazioni hardware">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE9D9;" />
                            <TextBlock Text="Prestazioni" />
                        </StackPanel>
                    </Button>
                    <Button Click="Continuity_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Continuità dispositivi" AutomationProperties.Name="Continuità dispositivi">
                        <StackPanel Orientation="Horizontal" Spacing="10"><FontIcon FontSize="15" Glyph="&#xE8C8;" /><TextBlock Text="Continuità" /></StackPanel>
                    </Button>
                    <Button Click="Audit_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Timeline audit" AutomationProperties.Name="Timeline audit"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon FontSize="15" Glyph="&#xE9D5;" /><TextBlock Text="Audit" /></StackPanel></Button>
                    <Button Click="Search_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Ricerca universale (Ctrl+K)" AutomationProperties.Name="Ricerca universale">
                        <StackPanel Orientation="Horizontal" Spacing="10"><FontIcon FontSize="15" Glyph="&#xE721;" /><TextBlock Text="Ricerca globale" /></StackPanel>
                    </Button>
                    <Button Click="Voice_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Voce" AutomationProperties.Name="Voce">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE720;" />
                            <TextBlock Text="Voce" />
                        </StackPanel>
                    </Button>
                    <Button Click="Video_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Video" AutomationProperties.Name="Video">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE714;" />
                            <TextBlock Text="Video" />
                        </StackPanel>
                    </Button>
                    <Button Click="Artifacts_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Artifact" AutomationProperties.Name="Artifact">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE8B7;" />
                            <TextBlock Text="Artifact" />
                        </StackPanel>
                    </Button>
                    <Button Click="News_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="News" AutomationProperties.Name="News">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE789;" />
                            <TextBlock Text="News" />
                        </StackPanel>
                    </Button>
                    <Button Click="Settings_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Impostazioni" AutomationProperties.Name="Impostazioni">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="15" Glyph="&#xE713;" />
                            <TextBlock Text="Impostazioni" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="18">
                    <Button Click="Projects_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Progetti" AutomationProperties.Name="Progetti">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Progetti" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text=">" />
                        </StackPanel>
                    </Button>
                    <Button Click="Archive_Click" Style="{StaticResource SidebarButtonStyle}" ToolTipService.ToolTip="Recenti" AutomationProperties.Name="Recenti">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Recenti" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text=">" />
                        </StackPanel>
                    </Button>
                    <StackPanel x:Name="RecentChatsPanel" Spacing="4" />
                </StackPanel>

                <Button
                    Grid.Row="3"
                    Padding="6"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="About_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    ToolTipService.ToolTip="Profilo"
                    AutomationProperties.Name="Profilo">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="28"
                            Height="28"
                            Background="#FF9B59B6"
                            CornerRadius="14">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="MP" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Matteo" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="Hermes locale" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="DragRegion"
                Background="{StaticResource AppBackgroundBrush}">
                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Padding="16,0,0,0">
                    <Button
                        x:Name="RestoreSidebarButton"
                        Width="32"
                        Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CollapseSidebar_Click"
                        Foreground="{StaticResource MutedTextBrush}"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Mostra sidebar"
                        AutomationProperties.Name="Mostra sidebar">
                        <FontIcon FontSize="14" Glyph="&#xE8A0;" />
                    </Button>
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Padding="0,0,16,8"
                    Spacing="10">
                    <Button
                        Width="32"
                        Height="32"
                        Click="Settings_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource MutedTextBrush}"
                        ToolTipService.ToolTip="Impostazioni"
                        AutomationProperties.Name="Impostazioni">
                        <FontIcon FontSize="14" Glyph="&#xE713;" />
                    </Button>
                </StackPanel>
            </Grid>

            <Frame x:Name="ContentFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
