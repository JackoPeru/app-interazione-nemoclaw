<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="1080" HorizontalAlignment="Stretch" Spacing="22">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="White" Text="Notifiche" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Messaggi autonomi che Hermes lascia quando cron o agenti devono avvisarti." TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" MinWidth="110" Click="Refresh_Click" Content="Aggiorna" />
                </Grid>

                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" Text="Caricamento notifiche..." />
                <StackPanel x:Name="NotificationsPanel" Spacing="12" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
