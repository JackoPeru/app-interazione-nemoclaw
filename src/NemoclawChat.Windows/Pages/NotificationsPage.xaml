<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="1080" HorizontalAlignment="Stretch" Spacing="22">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="White" Text="Notifiche" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Messaggi autonomi che Hermes lascia quando cron o agenti devono avvisarti." TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button MinWidth="110" Click="MarkAllAsRead_Click" Content="Segna tutto come letto" />
                        <Button MinWidth="110" Click="Refresh_Click" Content="Aggiorna" />
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" Text="Caricamento notifiche..." />
                <Border Padding="14" Background="{StaticResource SurfaceBrush}" CornerRadius="14">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox x:Name="CategoryFilterBox" Width="180" SelectionChanged="Filter_Changed" SelectedIndex="0"><ComboBoxItem Content="Tutte le categorie" /><ComboBoxItem Content="Automazioni" /><ComboBoxItem Content="Run" /><ComboBoxItem Content="Sistema" /><ComboBoxItem Content="File" /><ComboBoxItem Content="Progetti" /></ComboBox>
                            <ComboBox x:Name="PriorityFilterBox" Width="150" SelectionChanged="Filter_Changed" SelectedIndex="0"><ComboBoxItem Content="Tutte le priorità" /><ComboBoxItem Content="Critica" /><ComboBoxItem Content="Alta" /><ComboBoxItem Content="Normale" /><ComboBoxItem Content="Bassa" /></ComboBox>
                            <CheckBox x:Name="UnreadOnlyBox" Content="Solo non lette" Checked="Filter_Changed" Unchecked="Filter_Changed" />
                            <CheckBox x:Name="ArchivedBox" Content="Archiviate" Checked="Filter_Changed" Unchecked="Filter_Changed" />
                            <ToggleSwitch x:Name="DoNotDisturbSwitch" Header="Non disturbare" Toggled="DoNotDisturbSwitch_Toggled" />
                        </StackPanel>
                        <TextBlock x:Name="BadgesText" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
                <StackPanel x:Name="NotificationsPanel" Spacing="12" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
