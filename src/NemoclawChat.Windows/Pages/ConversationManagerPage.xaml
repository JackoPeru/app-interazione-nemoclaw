<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="NemoclawChat_Windows.Pages.ConversationManagerPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource AppBackgroundBrush}">
 <ScrollViewer><StackPanel Padding="36" Spacing="14"><TextBlock x:Name="TitleText" Text="Gestione conversazione" Foreground="White" FontSize="30" FontWeight="SemiBold" />
  <Border Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="18"><StackPanel Spacing="8"><TextBox x:Name="FolderBox" Header="Cartella" /><TextBox x:Name="TagsBox" Header="Tag" /><TextBox x:Name="ProjectBox" Header="Progetto" /><TextBox x:Name="LinksBox" Header="Chat collegate (ID)" /><TextBox x:Name="SummaryBox" Header="Riepilogo" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" /><StackPanel Orientation="Horizontal" Spacing="8"><Button Click="SaveMetadata_Click" Content="Salva metadata" /><Button Click="Summarize_Click" Content="Riassumi con Hermes" /><Button Click="DeleteSelected_Click" Content="Elimina selezionati" /></StackPanel></StackPanel></Border>
  <Border Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="18"><StackPanel Spacing="8"><TextBlock Text="Import / export" Foreground="White" FontWeight="SemiBold" /><StackPanel Orientation="Horizontal" Spacing="8"><Button Click="ExportMarkdown_Click" Content="Markdown" /><Button Click="ExportJson_Click" Content="JSON" /><Button Click="ExportPdf_Click" Content="PDF" /><Button Click="ExportHtml_Click" Content="HTML" /><Button Click="Import_Click" Content="Importa" /></StackPanel></StackPanel></Border>
  <TextBlock Text="Messaggi" Foreground="White" FontSize="20" FontWeight="SemiBold" /><StackPanel x:Name="MessagesPanel" Spacing="10" /><TextBlock Text="Rami e risposte alternative" Foreground="White" FontSize="20" FontWeight="SemiBold" /><StackPanel x:Name="BranchesPanel" Spacing="8" /><TextBlock x:Name="StatusText" Text="Pronto." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
 </StackPanel></ScrollViewer>
</Page>
