<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="860" Spacing="22">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Profilo e app" />
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="Info locale client. Nessun account cloud, nessun token provider nel client." />
                </StackPanel>

                <Border
                    Padding="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="64" Height="64" CornerRadius="18">
                            <Image
                                Width="64"
                                Height="64"
                                Source="ms-appx:///Assets/ChatClawLogo.png"
                                Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Matteo" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Profilo locale per home-server OpenClaw." />
                            <TextBlock x:Name="SettingsPathText" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="18" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Versione" />
                            <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="18" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Gateway" />
                            <TextBlock x:Name="GatewayText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Padding="18" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Privacy" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Chat e settings restano locali finche' non colleghi il gateway. Segreti e provider token restano lato server." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Padding="18" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Modalita" />
                            <TextBlock x:Name="ModeText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel Spacing="12">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Aggiornamenti" />
                        <TextBlock
                            x:Name="UpdateStatusText"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Controlla GitHub Releases per nuove versioni."
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button
                                Background="{StaticResource AccentGreenBrush}"
                                BorderThickness="0"
                                Click="CheckUpdates_Click"
                                Content="Controlla update"
                                Foreground="White" />
                            <Button
                                x:Name="OpenReleaseButton"
                                Click="OpenRelease_Click"
                                Content="Apri release"
                                IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
