<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.VideoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:NemoclawChat_Windows.Services"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <ScrollViewer>
            <Grid Padding="44,36" RowSpacing="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="30"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Video" />
                <TextBlock
                    MaxWidth="920"
                    Foreground="{StaticResource MutedTextBrush}"
                    Text="Feed automatico stile YouTube: ogni video messo nella cartella Hermes compare qui, con player locale, note rapide e feedback che Hermes deve usare per migliorare i prossimi output." />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource PremiumCardBorderStyle}">
                <Grid ColumnSpacing="14" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Foreground="White" Text="Cartella monitorata" />
                        <TextBlock x:Name="LibraryPathText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Click="OpenFolder_Click" Content="Apri cartella" />
                        <Button Click="Refresh_Click" Content="Aggiorna feed" />
                    </StackPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="ManualVideoUrlBox"
                            Header="URL video manuale"
                            PlaceholderText="https://..." />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Click="OpenManualVideoUrl_Click"
                            Content="Apri URL" />
                    </Grid>

                    <TextBlock
                        x:Name="PageStatusText"
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="Pronto." />
                </Grid>
            </Border>

                <Grid
                    x:Name="VideoContentGrid"
                    Grid.Row="2"
                    ColumnSpacing="18"
                    RowSpacing="18"
                    SizeChanged="VideoContentGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="VideoFeedPanel"
                    Style="{StaticResource PremiumCardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock FontWeight="SemiBold" Foreground="White" Text="Feed video" />
                        <ListView
                            x:Name="VideoListView"
                            IsItemClickEnabled="True"
                            ItemClick="VideoListView_ItemClick"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="services:LocalVideoRecord">
                                    <Grid Margin="0,0,0,14" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Height="101"
                                            Background="#FF232831"
                                            BorderBrush="#33FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid>
                                                <Rectangle RadiusX="8" RadiusY="8">
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#FF3A260B" Offset="0" />
                                                            <GradientStop Color="#FF1D222B" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>
                                                <FontIcon
                                                    FontSize="44"
                                                    Glyph="&#xE768;"
                                                    Foreground="#FFF5A524"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                                <Border
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="12"
                                                    Padding="8,4"
                                                    Background="#AA0F1115"
                                                    CornerRadius="999">
                                                    <TextBlock Foreground="White" Text="{x:Bind Extension}" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock
                                                Foreground="White"
                                                FontWeight="SemiBold"
                                                FontSize="16"
                                                Text="{x:Bind Title}"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{x:Bind FileName}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{x:Bind ModifiedLabel}" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{x:Bind SizeLabel}" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{x:Bind FeedbackCountLabel}" />
                                            <TextBlock
                                                Foreground="{StaticResource MutedTextBrush}"
                                                MaxLines="2"
                                                Text="{x:Bind FeedbackPreview}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="VideoDetailPanel"
                    Grid.Column="1"
                    Style="{StaticResource PremiumCardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock FontWeight="SemiBold" Foreground="White" Text="Video selezionato" />
                        <Grid
                            Height="260"
                            Background="Black"
                            DoubleTapped="VideoSurface_DoubleTapped">
                            <MediaPlayerElement
                                x:Name="VideoPlayer"
                                AreTransportControlsEnabled="True"
                                AutoPlay="False"
                                Stretch="Uniform" />
                            <Button
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10"
                                Padding="10,7"
                                Background="#AA0F1115"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                Click="FullScreen_Click"
                                CornerRadius="16"
                                Foreground="White"
                                AutomationProperties.Name="Guarda video a schermo intero">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="13" Glyph="&#xE740;" />
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="Schermo intero" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="SelectedVideoTitleText" Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Seleziona un video" />
                        <TextBlock x:Name="SelectedVideoMetaText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />

                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button HorizontalAlignment="Stretch" Click="QuickFeedback_Click" Tag="Hook piu' forte nei primi 5 secondi" Content="Hook" />
                            <Button Grid.Column="1" HorizontalAlignment="Stretch" Click="QuickFeedback_Click" Tag="Ritmo piu' veloce e meno pause" Content="Ritmo" />
                            <Button Grid.Row="1" HorizontalAlignment="Stretch" Click="QuickFeedback_Click" Tag="Piu' chiarezza didattica e step concreti" Content="Chiarezza" />
                            <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Click="QuickFeedback_Click" Tag="Montaggio piu' pulito e meno ridondanza" Content="Montaggio" />
                        </Grid>

                        <TextBox
                            x:Name="FeedbackBox"
                            Header="Feedback per Hermes"
                            AcceptsReturn="True"
                            MinHeight="120"
                            PlaceholderText="Es: intro lenta, serve hook piu' forte, voiceover piu' naturale, taglia 20 secondi finali..." />
                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="SendFeedbackButton"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource AccentGreenBrush}"
                                BorderThickness="0"
                                Click="SendFeedback_Click"
                                Content="Invia feedback a Hermes"
                                Foreground="White" />
                            <Button Grid.Column="1" Click="CopyPath_Click" Content="Copia path video" />
                        </Grid>
                        <TextBlock x:Name="FeedbackStatusText" Foreground="{StaticResource MutedTextBrush}" Text="Hermes deve usare questi feedback come memoria editoriale stabile quando appropriato." TextWrapping="Wrap" />
                        <TextBox
                            x:Name="AgentResponseBox"
                            MinHeight="180"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid
            x:Name="FullScreenVideoOverlay"
            Background="{StaticResource AppBackgroundBrush}"
            Padding="28"
            RowSpacing="16"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="FullScreenVideoTitleText"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Video" />
                    <TextBlock
                        x:Name="FullScreenVideoMetaText"
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="Riproduzione a schermo intero."
                        TextWrapping="Wrap" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="CloseFullScreen_Click"
                    Content="Chiudi" />
            </Grid>

            <Border
                Grid.Row="1"
                Background="Black"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18">
                <MediaPlayerElement
                    x:Name="FullScreenVideoPlayer"
                    AreTransportControlsEnabled="True"
                    AutoPlay="False"
                    Stretch="Uniform" />
            </Border>
        </Grid>
    </Grid>
</Page>
