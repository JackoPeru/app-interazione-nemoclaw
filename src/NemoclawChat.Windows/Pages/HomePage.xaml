<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NemoclawChat_Windows.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator
            Key="N"
            Modifiers="Control"
            Invoked="NewChat_Invoked" />
        <KeyboardAccelerator
            Key="L"
            Modifiers="Control"
            Invoked="ClearChat_Invoked" />
    </Page.KeyboardAccelerators>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="ErrorInfoBar"
            Grid.Row="0"
            Margin="24,4"
            IsClosable="True"
            IsOpen="False"
            Severity="Error" />

        <ScrollViewer
            x:Name="MessagesScroll"
            Grid.Row="1"
            Padding="24,64,24,18"
            VerticalScrollBarVisibility="Auto">
            <Grid MinHeight="620">
                <Grid
                    x:Name="EmptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="820">
                    <StackPanel HorizontalAlignment="Center" Spacing="18">
                        <Border
                            Width="108"
                            Height="108"
                            Background="#FF0A0F16"
                            CornerRadius="28">
                            <Image
                                Source="ms-appx:///Assets/ChatClawLogo.png"
                                Stretch="UniformToFill" />
                        </Border>
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Che vuoi fare oggi, Matteo?" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Chat normale, cron e strumenti Hermes Agent sul tuo home-server." />
                        <Grid
                            MaxWidth="430"
                            ColumnSpacing="10"
                            RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button
                                Padding="14,8"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                Click="PromptSetup_Click"
                                Content="Prepara setup Hermes"
                                CornerRadius="8"
                                Foreground="White" />
                            <Button
                                Grid.Column="1"
                                Padding="14,8"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                Click="PromptHealth_Click"
                                Content="Controlla server"
                                CornerRadius="8"
                                Foreground="White" />
                            <Button
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Padding="14,8"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                Click="PromptAgent_Click"
                                Content="Crea ordine agente"
                                CornerRadius="8"
                                Foreground="White" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <ListView
                    x:Name="MessagesList"
                    MaxWidth="860"
                    HorizontalAlignment="Stretch"
                    Padding="0,32,0,32"
                    Background="Transparent"
                    BorderThickness="0"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind Messages, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,0,0,18" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:MessageViewModel">
                            <ContentControl Content="{x:Bind Element}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </ScrollViewer>

        <StackPanel
            Grid.Row="1"
            Margin="0,20,34,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="NewChatButton"
                MinWidth="100"
                Padding="12,7"
                Background="{StaticResource ElevatedSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                Click="NewChat_Click"
                CornerRadius="18"
                Foreground="White"
                AutomationProperties.Name="Nuova chat"
                ToolTipService.ToolTip="Inizia una nuova chat">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <FontIcon FontSize="14" Glyph="&#xE70F;" />
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="Nuova" />
                </StackPanel>
            </Button>
            <Border
                x:Name="ContextMeter"
                Width="54"
                Height="54"
                Background="{StaticResource ElevatedSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="27"
                AutomationProperties.Name="Contesto chat">
                <Grid Width="54" Height="54">
                    <Ellipse Fill="#FF111821" />
                    <Path
                        x:Name="ContextMeterFill"
                        Fill="{StaticResource AccentGreenBrush}"
                        Opacity="0.88" />
                    <Ellipse
                        Margin="3"
                        Stroke="{StaticResource AccentGreenBrush}"
                        StrokeThickness="1.25"
                        Opacity="0.72" />
                    <TextBlock
                        x:Name="ContextMeterText"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="0%" />
                </Grid>
            </Border>
        </StackPanel>

        <Grid
            Grid.Row="2"
            Padding="24,0,24,28"
            HorizontalAlignment="Stretch">
            <Border
                MaxWidth="1040"
                MinHeight="58"
                HorizontalAlignment="Stretch"
                Background="{StaticResource ComposerBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="30">
                <Grid Padding="14,8,10,8" RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        x:Name="AttachmentPreviewPanel"
                        Grid.Row="0"
                        Padding="4,0,4,8"
                        Spacing="8"
                        Visibility="Collapsed" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button
                            x:Name="PlusButton"
                            Width="38"
                            Height="38"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource MutedTextBrush}"
                            AutomationProperties.Name="Azioni e allegati">
                            <FontIcon FontSize="16" Glyph="&#xE710;" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Click="AttachFile_Click" Text="Aggiungi file al task">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8B7;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="PasteImage_Click" Text="Incolla immagine">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8B9;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="CaptureScreenshot_Click" Text="Cattura screenshot">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE722;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="TakePhoto_Click" Text="Scatta foto">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE722;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Click="SetModeChat_Click" Text="Passa a modalita Chat">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8BD;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="SetModeAgent_Click" Text="Passa a modalita Agente">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE7BE;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Click="CreateImage_Click" Text="Crea immagine">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xEB9F;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="DeepResearch_Click" Text="Deep Research locale">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE721;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="WebSearch_Click" Text="Ricerca web autorizzata">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE774;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="VisualExplanation_Click" Text="Spiegazione visiva">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE9D2;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Click="Projects_Click" Text="Progetti / workspace">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8F1;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <TextBox
                            x:Name="PromptBox"
                            Grid.Column="1"
                            MinHeight="40"
                            MaxHeight="180"
                            AcceptsReturn="False"
                            AllowDrop="True"
                            AutomationProperties.Name="Prompt input"
                            Background="Transparent"
                            BorderThickness="0"
                            DragOver="PromptBox_DragOver"
                            Drop="PromptBox_Drop"
                            Foreground="White"
                            IsSpellCheckEnabled="True"
                            KeyDown="PromptBox_KeyDown"
                            MaxLength="50000"
                            PlaceholderForeground="{StaticResource MutedTextBrush}"
                            PlaceholderText="Fai una domanda"
                            Paste="PromptBox_Paste"
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="2"
                            Width="38"
                            Height="38"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="VoiceNote_Click"
                            Foreground="{StaticResource MutedTextBrush}"
                            AutomationProperties.Name="Nota vocale">
                            <FontIcon FontSize="16" Glyph="&#xE720;" />
                        </Button>

                        <Button
                            x:Name="SendButton"
                            Grid.Column="3"
                            Width="42"
                            Height="42"
                            Background="White"
                            BorderThickness="0"
                            Click="Send_Click"
                            CornerRadius="21"
                            Foreground="#FF111111"
                            AutomationProperties.Name="Invia messaggio">
                            <FontIcon FontSize="16" Glyph="&#xE724;" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
