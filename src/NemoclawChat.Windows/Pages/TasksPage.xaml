<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="980" HorizontalAlignment="Left" Spacing="22">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Jobs" />
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="Coda Jobs persistente. Usa Hermes Jobs API quando disponibile, altrimenti fallback locale." />
                </StackPanel>

                <Border
                    Padding="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel Spacing="14">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Nuovo job" />
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                x:Name="TaskTitleBox"
                                Header="Titolo job"
                                PlaceholderText="Es. Analizza workspace" />
                            <ComboBox
                                x:Name="TaskModeBox"
                                Grid.Column="1"
                                Header="Modalita"
                                SelectedIndex="0">
                                <ComboBoxItem Content="Locale" />
                                <ComboBoxItem Content="Hermes" />
                                <ComboBoxItem Content="Sicuro" />
                            </ComboBox>
                            <TextBox
                                x:Name="TaskDetailBox"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                AcceptsReturn="True"
                                Header="Istruzioni"
                                MaxHeight="140"
                                PlaceholderText="Descrivi il job da eseguire tramite Hermes Agent."
                                TextWrapping="Wrap" />
                            <ToggleSwitch
                                x:Name="ApprovalSwitch"
                                Grid.Row="2"
                                Header="Richiedi conferma prima di azioni rischiose"
                                IsOn="True" />
                        </Grid>

                        <TextBlock
                            x:Name="TaskStatusText"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Pronto." />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button
                                Background="{StaticResource AccentGreenBrush}"
                                BorderThickness="0"
                                Click="QueueTask_Click"
                                Content="Crea job"
                                Foreground="White" />
                            <Button Click="LoadWorkspaceTemplate_Click" Content="Template workspace" />
                            <Button Click="LoadServerTemplate_Click" Content="Template server" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="TasksPanel" Spacing="14" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
