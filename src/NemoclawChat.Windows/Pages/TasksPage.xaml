<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="44,36" Background="{StaticResource AppBackgroundBrush}">
        <StackPanel MaxWidth="920" HorizontalAlignment="Left" Spacing="24">
            <TextBlock
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="White"
                Text="Ordini agente" />
            <TextBlock
                Foreground="{StaticResource MutedTextBrush}"
                Text="Qui compariranno task NemoClaw, tool call, comandi, file modificati e richieste approve/deny." />

            <Border
                Padding="22"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="12">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="Nessun task attivo" />
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Demo mode: quando il gateway sara' online useremo /api/tasks, /api/tasks/{id}/events e approve/deny." />
                    <Button Content="Nuovo ordine agente" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
