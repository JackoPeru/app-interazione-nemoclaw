<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.VoicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    Background="Black"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">
    <Grid
        x:Name="Root"
        Background="Black"
        IsTabStop="True"
        KeyDown="Root_KeyDown">
        <canvas:CanvasAnimatedControl
            x:Name="ParticleCanvas"
            ClearColor="Black"
            Draw="ParticleCanvas_Draw"
            IsFixedTimeStep="False"
            Update="ParticleCanvas_Update" />

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,36"
            Spacing="12">
            <Button
                x:Name="CallButton"
                Width="76"
                Height="76"
                Padding="0"
                Click="CallButton_Click"
                CornerRadius="38"
                HorizontalAlignment="Center"
                Background="#22FFFFFF"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                ToolTipService.ToolTip="Avvia o chiudi chiamata con Hermes"
                AutomationProperties.Name="Avvia o chiudi chiamata con Hermes">
                <FontIcon x:Name="CallIcon" Glyph="&#xE717;" FontSize="28" Foreground="White" />
            </Button>
            <TextBlock
                x:Name="StatusText"
                Width="520"
                Text="Hermes voce pronto."
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                Foreground="#B8FFFFFF"
                FontSize="13" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button x:Name="InterruptButton" Click="Interrupt_Click" Content="Interrompi Hermes" IsEnabled="False" />
                <Button x:Name="PttButton" Click="Ptt_Click" Content="Premi per parlare" />
                <Button Click="ToggleTranscript_Click" Content="Trascrizione" />
                <Button Click="SwitchToText_Click" Content="Passa a testo" />
            </StackPanel>
        </StackPanel>

        <Border Width="320" Margin="20" Padding="14" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC151515" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="14">
            <StackPanel Spacing="9"><TextBlock Text="Profilo voce" Foreground="White" FontWeight="SemiBold" />
                <ComboBox x:Name="VoiceBox" Header="Voce" SelectedIndex="0"><ComboBoxItem Content="if_sara" /><ComboBoxItem Content="im_nicola" /><ComboBoxItem Content="if_alba" /></ComboBox>
                <Slider x:Name="SpeedSlider" Header="Velocità" Minimum="0.75" Maximum="1.35" Value="1.08" StepFrequency="0.05" />
                <TextBox x:Name="ProjectProfileBox" Header="Profilo progetto" PlaceholderText="ID progetto opzionale" />
                <ToggleSwitch x:Name="WakeWordSwitch" Header="Wake word 'Hermes'" />
                <StackPanel Orientation="Horizontal" Spacing="8"><Button Click="PreviewVoice_Click" Content="Anteprima" /><Button Click="SaveVoiceProfile_Click" Content="Salva profilo" /></StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="TranscriptBorder" Width="440" MaxHeight="520" Margin="20,90,20,150" Padding="14" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="#DD151515" CornerRadius="14" Visibility="Collapsed">
            <ScrollViewer><TextBlock x:Name="TranscriptText" Foreground="White" TextWrapping="Wrap" /></ScrollViewer>
        </Border>

        <Button
            Width="40"
            Height="40"
            Margin="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="Back_Click"
            Background="#18000000"
            BorderBrush="#35FFFFFF"
            BorderThickness="1"
            ToolTipService.ToolTip="Torna alla chat"
            AutomationProperties.Name="Torna alla chat">
            <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="#DDFFFFFF" />
        </Button>
    </Grid>
</Page>
