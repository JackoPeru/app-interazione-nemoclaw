<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.VoicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">
    <Grid
        x:Name="Root"
        Background="Black"
        IsTabStop="True"
        KeyDown="Root_KeyDown">
        <Canvas
            x:Name="ParticleCanvas"
            Background="Black"
            SizeChanged="ParticleCanvas_SizeChanged" />

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,36"
            Spacing="12">
            <Button
                x:Name="CallButton"
                Width="76"
                Height="76"
                Padding="0"
                Click="CallButton_Click"
                CornerRadius="38"
                HorizontalAlignment="Center"
                Background="#22FFFFFF"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                ToolTipService.ToolTip="Avvia o chiudi chiamata con Hermes"
                AutomationProperties.Name="Avvia o chiudi chiamata con Hermes">
                <FontIcon x:Name="CallIcon" Glyph="&#xE717;" FontSize="28" Foreground="White" />
            </Button>
            <TextBlock
                x:Name="StatusText"
                Width="520"
                Text="Hermes voce pronto."
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                Foreground="#B8FFFFFF"
                FontSize="13" />
        </StackPanel>

        <Button
            Width="40"
            Height="40"
            Margin="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="Back_Click"
            Background="#18000000"
            BorderBrush="#35FFFFFF"
            BorderThickness="1"
            ToolTipService.ToolTip="Torna alla chat"
            AutomationProperties.Name="Torna alla chat">
            <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="#DDFFFFFF" />
        </Button>
    </Grid>
</Page>
