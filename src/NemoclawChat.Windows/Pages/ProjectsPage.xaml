<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="28" ColumnSpacing="20" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" Spacing="6">
            <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="White" Text="Progetti" />
            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Scegli un nome e, se serve, un system prompt personalizzato. Il resto e' automatico." />
        </StackPanel>

        <Border Grid.Row="1" Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button HorizontalAlignment="Stretch" Click="NewProject_Click" Content="+ Nuovo progetto" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ProjectListPanel" Spacing="8" />
                </ScrollViewer>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Border MaxWidth="760" Padding="22" HorizontalAlignment="Stretch" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DashboardTitle" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Nuovo progetto" />
                        <TextBlock x:Name="ActiveBadge" Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource AccentGreenBrush}" />
                    </Grid>
                    <TextBox x:Name="TitleBox" Header="Nome progetto" MaxLength="180" />
                    <TextBox
                        x:Name="SystemPromptBox"
                        Header="System prompt (facoltativo)"
                        PlaceholderText="Istruzioni personalizzate valide in tutte le chat del progetto"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MaxLength="20000"
                        MinHeight="180" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="SaveProject_Click" Content="Salva" />
                        <Button x:Name="NewChatButton" Click="NewProjectChat_Click" Content="Nuova chat nel progetto" IsEnabled="False" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" Text="Pronto." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
