<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.OperatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="1080" HorizontalAlignment="Left" Spacing="22">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Runs" />
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="Operazioni reali verso Hermes Agent API: health, models, capabilities, runs e jobs." />
                </StackPanel>

                <Border Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                    <StackPanel Spacing="12">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Preset Hermes" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Text="Ogni preset chiama un endpoint Hermes reale; errori HTTP restano visibili." TextWrapping="Wrap" />
                        <VariableSizedWrapGrid x:Name="PresetPanel" Orientation="Horizontal" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="12">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Endpoint manuale" />
                            <TextBox x:Name="MethodBox" Header="Metodo + path" Text="GET /health" />
                            <TextBox
                                x:Name="ParamsBox"
                                AcceptsReturn="True"
                                Header="Body JSON"
                                MinHeight="160"
                                TextWrapping="Wrap" />
                            <Button
                                Background="{StaticResource AccentGreenBrush}"
                                BorderThickness="0"
                                Click="RunRpc_Click"
                                Content="Esegui"
                                Foreground="White" />
                            <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" Text="Pronto." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="12">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Risposta Hermes" />
                            <TextBlock x:Name="SummaryText" Foreground="{StaticResource MutedTextBrush}" Text="Nessuna risposta." TextWrapping="Wrap" />
                            <TextBox
                                x:Name="ResultBox"
                                AcceptsReturn="True"
                                FontFamily="Consolas"
                                FontSize="12"
                                IsReadOnly="True"
                                MinHeight="420"
                                TextWrapping="NoWrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Jobs" />
                            <TextBox x:Name="ApprovalIdBox" Header="Job ID" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="RefreshApprovals_Click" Content="Lista" />
                                <Button Click="ApproveOnce_Click" Content="Run" />
                                <Button Click="ApproveAlways_Click" Content="Run" />
                                <Button Click="DenyApproval_Click" Content="Pausa" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Runs manuali" />
                            <TextBox x:Name="ConfigBaseHashBox" Header="Run ID" />
                            <TextBox x:Name="ConfigPatchBox" AcceptsReturn="True" Header="Input JSON/string" MinHeight="96" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="ReadConfig_Click" Content="Capabilities" />
                                <Button Click="PatchConfig_Click" Content="Crea run" />
                                <Button Click="ApplyConfig_Click" Content="Models" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Diagnostica" />
                            <TextBox x:Name="WorkspacePathBox" Header="Filtro job" PlaceholderText="opzionale" />
                            <TextBox x:Name="WorkspaceTextBox" AcceptsReturn="True" Header="Input run rapido" MinHeight="96" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="WorkspaceList_Click" Content="Jobs" />
                                <Button Click="WorkspaceRead_Click" Content="Health" />
                                <Button Click="WorkspaceWrite_Click" Content="Run" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18" Visibility="Collapsed">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Admin Bridge" />
                            <TextBox x:Name="AdminPathBox" Header="Path/log" PlaceholderText="/home/matteo/hermes-workspace" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="AdminStatus_Click" Content="Status" />
                                <Button Click="AdminDoctor_Click" Content="Doctor" />
                                <Button Click="AdminSecurity_Click" Content="Audit" />
                                <Button Click="AdminRestart_Click" Content="Restart" />
                                <Button Click="AdminTail_Click" Content="Tail log" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
