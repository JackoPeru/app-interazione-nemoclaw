<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.OperatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="1080" HorizontalAlignment="Left" Spacing="22">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Console Operatore" />
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="RPC reali verso OpenClaw Gateway WS. Nessun preset e' locale: ogni azione chiama il Gateway." />
                </StackPanel>

                <Border Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                    <StackPanel Spacing="12">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Preset RPC" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Text="Se il Gateway non supporta un metodo, vedrai errore RPC reale." TextWrapping="Wrap" />
                        <VariableSizedWrapGrid x:Name="PresetPanel" Orientation="Horizontal" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="12">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="RPC manuale" />
                            <TextBox x:Name="MethodBox" Header="Metodo" Text="status" />
                            <TextBox
                                x:Name="ParamsBox"
                                AcceptsReturn="True"
                                Header="Params JSON"
                                MinHeight="160"
                                TextWrapping="Wrap" />
                            <Button
                                Background="{StaticResource AccentGreenBrush}"
                                BorderThickness="0"
                                Click="RunRpc_Click"
                                Content="Esegui RPC"
                                Foreground="White" />
                            <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" Text="Pronto." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="12">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Risposta Gateway" />
                            <TextBlock x:Name="SummaryText" Foreground="{StaticResource MutedTextBrush}" Text="Nessuna risposta." TextWrapping="Wrap" />
                            <TextBox
                                x:Name="ResultBox"
                                AcceptsReturn="True"
                                FontFamily="Consolas"
                                FontSize="12"
                                IsReadOnly="True"
                                MinHeight="420"
                                TextWrapping="NoWrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Approvazioni exec" />
                            <TextBox x:Name="ApprovalIdBox" Header="Approval ID" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="RefreshApprovals_Click" Content="Pending" />
                                <Button Click="ApproveOnce_Click" Content="Allow once" />
                                <Button Click="ApproveAlways_Click" Content="Allow always" />
                                <Button Click="DenyApproval_Click" Content="Deny" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Config patch" />
                            <TextBox x:Name="ConfigBaseHashBox" Header="baseHash" />
                            <TextBox x:Name="ConfigPatchBox" AcceptsReturn="True" Header="Patch JSON" MinHeight="96" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="ReadConfig_Click" Content="Leggi" />
                                <Button Click="PatchConfig_Click" Content="Patch" />
                                <Button Click="ApplyConfig_Click" Content="Apply" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Workspace / file" />
                            <TextBox x:Name="WorkspacePathBox" Header="Path consentito" PlaceholderText="~/openclaw-workspace" />
                            <TextBox x:Name="WorkspaceTextBox" AcceptsReturn="True" Header="Testo file" MinHeight="96" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="WorkspaceList_Click" Content="Lista" />
                                <Button Click="WorkspaceRead_Click" Content="Leggi" />
                                <Button Click="WorkspaceWrite_Click" Content="Scrivi" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Padding="20" Background="{StaticResource SurfaceBrush}" CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="Admin Bridge" />
                            <TextBox x:Name="AdminPathBox" Header="Path/log" PlaceholderText="/home/matteo/openclaw-workspace" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="AdminStatus_Click" Content="Status" />
                                <Button Click="AdminDoctor_Click" Content="Doctor" />
                                <Button Click="AdminSecurity_Click" Content="Audit" />
                                <Button Click="AdminRestart_Click" Content="Restart" />
                                <Button Click="AdminTail_Click" Content="Tail log" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
