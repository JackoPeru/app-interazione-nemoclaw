<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="36" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock
                    FontSize="30"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Prestazioni" />
                <TextBlock x:Name="HostText" Foreground="White" TextWrapping="Wrap" />
                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="Refresh_Click"
                Content="Aggiorna"
                VerticalAlignment="Top" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PremiumCardBorderStyle}" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ComponentsPanel" Spacing="8" />
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PremiumCardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Spacing="18" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
