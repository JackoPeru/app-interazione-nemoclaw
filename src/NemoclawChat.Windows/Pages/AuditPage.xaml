<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="NemoclawChat_Windows.Pages.AuditPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource AppBackgroundBrush}">
 <Grid Padding="36"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
  <StackPanel Spacing="10"><TextBlock Text="Timeline audit" Foreground="White" FontSize="30" FontWeight="SemiBold" /><TextBlock Text="Eventi unificati di chat, run, tool, automazioni, dispositivi e operazioni server." Foreground="{StaticResource MutedTextBrush}" />
   <StackPanel Orientation="Horizontal" Spacing="8"><TextBox x:Name="ProjectBox" Width="150" Header="Progetto" /><TextBox x:Name="RunBox" Width="150" Header="Run" /><TextBox x:Name="ToolBox" Width="150" Header="Tool" /><TextBox x:Name="DeviceBox" Width="150" Header="Dispositivo" /><ComboBox x:Name="RiskBox" Width="130" Header="Rischio" SelectedIndex="0"><ComboBoxItem Content="Tutti" /><ComboBoxItem Content="low" /><ComboBoxItem Content="medium" /><ComboBoxItem Content="high" /><ComboBoxItem Content="critical" /></ComboBox><Button Click="Refresh_Click" Content="Applica filtri" VerticalAlignment="Bottom" /></StackPanel>
   <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" />
  </StackPanel>
  <ScrollViewer Grid.Row="1" Margin="0,14,0,0"><StackPanel x:Name="TimelinePanel" Spacing="8" /></ScrollViewer>
 </Grid>
</Page>
