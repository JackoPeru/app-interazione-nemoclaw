<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="NemoclawChat_Windows.Pages.ContinuityPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource AppBackgroundBrush}">
 <ScrollViewer><StackPanel Padding="36" Spacing="14"><TextBlock Text="Continuità dispositivi" Foreground="White" FontSize="30" FontWeight="SemiBold" /><TextBlock Text="Riprendi chat, trasferisci voce, clipboard e file tra Windows e Android. Stato e conflitti restano visibili." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
  <Border Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="18"><StackPanel Spacing="10"><TextBlock Text="Questo dispositivo" Foreground="White" FontWeight="SemiBold" /><TextBlock x:Name="DeviceText" Foreground="{StaticResource MutedTextBrush}" /><StackPanel Orientation="Horizontal" Spacing="8"><Button Click="PublishPresence_Click" Content="Pubblica presenza" /><Button Click="ResumeLatest_Click" Content="Riprendi chat attiva" /><Button Click="TransferVoice_Click" Content="Trasferisci chiamata qui" /><Button Click="FlushQueue_Click" Content="Sincronizza coda offline" /></StackPanel><TextBlock x:Name="SyncText" Foreground="{StaticResource AccentGreenBrush}" /></StackPanel></Border>
  <Border Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="18"><StackPanel Spacing="10"><TextBlock Text="Clipboard e file" Foreground="White" FontWeight="SemiBold" /><TextBox x:Name="ClipboardBox" Header="Clipboard condivisa" AcceptsReturn="True" MinHeight="80" /><StackPanel Orientation="Horizontal" Spacing="8"><Button Click="SendClipboard_Click" Content="Invia clipboard" /><Button Click="ReceiveClipboard_Click" Content="Ricevi clipboard" /><Button Click="SendFile_Click" Content="Invia file al telefono" /></StackPanel></StackPanel></Border>
  <TextBlock Text="Dispositivi e handoff" Foreground="White" FontSize="20" FontWeight="SemiBold" /><StackPanel x:Name="ItemsPanel" Spacing="8" /><TextBlock Text="Conflitti" Foreground="White" FontSize="20" FontWeight="SemiBold" /><StackPanel x:Name="ConflictsPanel" Spacing="8" /><TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" />
 </StackPanel></ScrollViewer>
</Page>
