<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.NewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}">
        <Grid Padding="44,36" RowSpacing="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="30"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="News" />
                <TextBlock
                    MaxWidth="820"
                    Foreground="{StaticResource MutedTextBrush}"
                    Text="Sezione separata per ricerche, briefing e aggiornamenti periodici che Hermes potra' preparare senza sporcare la chat principale." />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PremiumCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Nuovo briefing news" />
                        <TextBlock
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Definisci argomento, fonti desiderate, frequenza e formato del report." />
                        <TextBox
                            x:Name="NewsPromptBox"
                            MinHeight="130"
                            AcceptsReturn="True"
                            Header="Brief news"
                            PlaceholderText="Esempio: tienimi aggiornato ogni mattina su AI agent e home-server..."
                            TextWrapping="Wrap" />
                        <Button
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentGreenBrush}"
                            BorderThickness="0"
                            Click="PrepareNews_Click"
                            Content="Prepara ricerca Hermes"
                            Foreground="White" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PremiumCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Pipeline futura" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="1. Argomenti e priorita" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="2. Fonti e filtri" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="3. Sintesi con citazioni" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="4. Automazioni e notifiche quando Hermes supportera' schedulazione news" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource PremiumCardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Stato" />
                    <TextBlock
                        x:Name="NewsStatusText"
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="Pronto. Questa sezione e' separata dalla chat e pensata per future ricerche/briefing Hermes." />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
