{
  "hermes": {
    "apiUrl": "http://hermes.local:8642/v1",
    "healthUrl": "http://hermes.local:8642/health",
    "detailedHealthUrl": "http://hermes.local:8642/health/detailed",
    "capabilitiesPath": "/v1/capabilities",
    "modelsPath": "/v1/models",
    "responsesPath": "/v1/responses",
    "chatCompletionsPath": "/v1/chat/completions",
    "runsPath": "/v1/runs",
    "jobsPath": "/api/jobs",
    "model": "hermes-agent",
    "preferredApi": "hermes-native",
    "strictNativeMode": false,
    "autoDiscoveryUrls": [
      "http://hermes.local:8642/v1",
      "http://hermes:8642/v1",
      "http://hermes-hub:8642/v1",
      "http://hermeshub:8642/v1",
      "http://home-server:8642/v1",
      "http://server:8642/v1"
    ]
  },
  "security": {
    "recommendedAccess": "Tailscale/LAN",
    "authHeader": "Authorization: Bearer hermes-hub, then no-auth fallback",
    "releaseCleartextTraffic": true,
    "storeProviderSecretsInClient": false
  }
}
