{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/schemas/visual-blocks.v1.schema.json",
  "title": "Hermes Visual Blocks v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["output_text"],
  "properties": {
    "output_text": { "type": "string", "minLength": 1 },
    "visual_blocks_version": { "type": "integer", "const": 1 },
    "visual_blocks": {
      "type": "array",
      "maxItems": 20,
      "items": { "$ref": "#/$defs/block" }
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[A-Za-z0-9_.:-]+$" },
    "plain120": { "type": "string", "maxLength": 120 },
    "plain300": { "type": "string", "maxLength": 300 },
    "block": {
      "oneOf": [
        { "$ref": "#/$defs/markdown_block" },
        { "$ref": "#/$defs/code_block" },
        { "$ref": "#/$defs/table_block" },
        { "$ref": "#/$defs/chart_block" },
        { "$ref": "#/$defs/diagram_block" },
        { "$ref": "#/$defs/image_gallery_block" },
        { "$ref": "#/$defs/callout_block" }
      ]
    },
    "common": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "type": "string" },
        "title": { "$ref": "#/$defs/plain120" },
        "caption": { "$ref": "#/$defs/plain300" }
      }
    },
    "markdown_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "text"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "markdown" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "text": { "type": "string", "maxLength": 80000 }
          },
          "additionalProperties": false
        }
      ]
    },
    "code_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "language", "code"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "code" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "language": {
              "enum": ["plaintext", "mermaid", "powershell", "bash", "json", "xml", "csharp", "kotlin", "python", "javascript", "typescript", "sql", "yaml", "markdown"]
            },
            "filename": { "type": "string", "maxLength": 160 },
            "code": { "type": "string", "maxLength": 80000 },
            "highlight_lines": {
              "type": "array",
              "maxItems": 80,
              "items": { "type": "integer", "minimum": 1 }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "table_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "columns", "rows"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "table" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "columns": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "#/$defs/table_column" } },
            "rows": {
              "type": "array",
              "maxItems": 100,
              "items": {
                "type": "object",
                "additionalProperties": { "type": ["string", "number", "integer", "boolean", "null"] }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "table_column": {
      "type": "object",
      "required": ["key", "label"],
      "properties": {
        "key": { "type": "string", "minLength": 1, "maxLength": 80 },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "align": { "enum": ["left", "center", "right"], "default": "left" },
        "format": { "enum": ["text", "number", "percent", "currency", "date", "code"], "default": "text" },
        "sortable": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "chart_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "chart_type", "summary", "series"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "chart" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "chart_type": { "enum": ["bar", "line"] },
            "x_label": { "type": "string", "maxLength": 80 },
            "y_label": { "type": "string", "maxLength": 80 },
            "unit": { "type": "string", "maxLength": 40 },
            "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
            "series": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "$ref": "#/$defs/chart_series" } }
          },
          "additionalProperties": false
        }
      ]
    },
    "chart_series": {
      "type": "object",
      "required": ["name", "points"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "points": { "type": "array", "minItems": 1, "maxItems": 200, "items": { "$ref": "#/$defs/chart_point" } }
      },
      "additionalProperties": false
    },
    "chart_point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": ["string", "number", "integer"] },
        "y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "diagram_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "source_format", "source", "alt"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "diagram" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "source_format": { "const": "mermaid" },
            "source": { "type": "string", "minLength": 1, "maxLength": 80000 },
            "rendered_media_url": { "type": "string", "maxLength": 1000 },
            "alt": { "type": "string", "minLength": 1, "maxLength": 300 }
          },
          "additionalProperties": false
        }
      ]
    },
    "image_gallery_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "layout", "images"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "image_gallery" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "layout": { "const": "grid" },
            "images": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "#/$defs/gallery_image" } }
          },
          "additionalProperties": false
        }
      ]
    },
    "gallery_image": {
      "type": "object",
      "required": ["media_url", "alt"],
      "properties": {
        "media_url": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "alt": { "type": "string", "minLength": 1, "maxLength": 300 },
        "caption": { "$ref": "#/$defs/plain300" }
      },
      "additionalProperties": false
    },
    "callout_block": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["id", "type", "variant", "text"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "callout" },
            "title": { "$ref": "#/$defs/plain120" },
            "caption": { "$ref": "#/$defs/plain300" },
            "variant": { "enum": ["info", "warning", "error", "success"] },
            "text": { "type": "string", "maxLength": 80000 }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
